DMDATA_API_KEY=your_dmdata_api_key_here

PORT=3000
NODE_ENV=development

# development: including
# production: excluding
DMDATA_TEST_MODE=excluding

# true only when you want to save received telegram samples to local files
SAVE_TELEGRAM_SAMPLE=false

# PostgreSQL connection string. Leave empty to disable DB saving.
DATABASE_URL=

# Save raw DMDATA telegrams only for debugging or short-term replay.
SAVE_RAW_TELEGRAMS=false
RAW_TELEGRAM_RETENTION_DAYS=14
